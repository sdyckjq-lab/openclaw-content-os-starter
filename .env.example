# Fill only what you actually use.
# Leave unused lines blank.

# Local content root
CONTENT_OS_HOME=$HOME/Documents/openclaw-content-os-data

# Pick at least one model provider you already use in OpenClaw.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional single chat entry
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Optional publishing integrations
WECHAT_APP_ID=
WECHAT_APP_SECRET=
X_API_KEY=
