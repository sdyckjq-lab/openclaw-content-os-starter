# Fill only what you actually use.
# Leave unused lines blank.

# Fresh-machine installer settings
# One provider + one key is enough for beginners.
OPENCLAW_CONTENT_OS_PROVIDER=
OPENCLAW_CONTENT_OS_MODEL=
OPENCLAW_CONTENT_OS_CUSTOM_BASE_URL=
OPENCLAW_CONTENT_OS_CUSTOM_MODEL_ID=
OPENCLAW_CONTENT_OS_CUSTOM_COMPATIBILITY=openai

# Local content root
CONTENT_OS_HOME=$HOME/Documents/openclaw-content-os-data

# Recommended for Chinese users first.
MINIMAX_API_KEY=
MOONSHOT_API_KEY=
ZAI_API_KEY=

# More common international providers.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
CUSTOM_API_KEY=

# Optional single chat entry
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Optional publishing integrations
WECHAT_APP_ID=
WECHAT_APP_SECRET=
X_API_KEY=
