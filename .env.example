# Fill only what you actually use.
# Leave unused lines blank.

# Fresh-machine installer settings
# One provider + one key is enough for beginners.
OPENCLAW_CONTENT_OS_PROVIDER=
OPENCLAW_CONTENT_OS_MODEL=

# Local content root
CONTENT_OS_HOME=$HOME/Documents/openclaw-content-os-data

# Pick only the provider you actually want to use.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional single chat entry
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Optional publishing integrations
WECHAT_APP_ID=
WECHAT_APP_SECRET=
X_API_KEY=
