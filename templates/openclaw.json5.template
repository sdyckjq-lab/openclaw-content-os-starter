// Copy only the sections you need into ~/.openclaw/openclaw.json.
// This is a sanitized starter template.
// Fresh installs usually use starter-* agent IDs and workspace-starter-* workspaces.
// If your install reused another prefix, prefer ~/.openclaw/openclaw.content-os.template.json5.
// Beginner default: let all 5 starter agents share the same default model.
// Advanced users can override models per agent with agents.list[].model.

{
  // Example of one shared default model for all starter agents:
  // agents: {
  //   defaults: {
  //     model: { primary: "openai/gpt-5.2" },
  //   },
  // },

  agents: {
    list: [
      {
        id: "starter-boss",
        default: true,
        name: "Starter Boss",
        workspace: "~/.openclaw/workspace-starter-boss",
        agentDir: "~/.openclaw/agents/starter-boss/agent",
        // Optional model override:
        // model: { primary: "your-provider/your-model" },
      },
      {
        id: "starter-material",
        name: "Starter Material",
        workspace: "~/.openclaw/workspace-starter-material",
        agentDir: "~/.openclaw/agents/starter-material/agent",
      },
      {
        id: "starter-creator",
        name: "Starter Creator",
        workspace: "~/.openclaw/workspace-starter-creator",
        agentDir: "~/.openclaw/agents/starter-creator/agent",
      },
      {
        id: "starter-thinktank",
        name: "Starter Thinktank",
        workspace: "~/.openclaw/workspace-starter-thinktank",
        agentDir: "~/.openclaw/agents/starter-thinktank/agent",
      },
      {
        id: "starter-tech",
        name: "Starter Tech",
        workspace: "~/.openclaw/workspace-starter-tech",
        agentDir: "~/.openclaw/agents/starter-tech/agent",
      },
    ],
  },

  tools: {
    agentToAgent: {
      enabled: true,
      allow: [
        "starter-boss",
        "starter-material",
        "starter-creator",
        "starter-thinktank",
        "starter-tech",
      ],
    },
  },

  // Optional: one single Telegram entry that routes to the boss only.
  // Start without this if you are a beginner.
  // bindings: [
  //   {
  //     agentId: "starter-boss",
  //     match: { channel: "telegram", accountId: "starter-telegram" },
  //   },
  // ],
  // channels: {
  //   telegram: {
  //     accounts: {
  //       "starter-telegram": {
  //         botToken: "${OPENCLAW_CONTENT_OS_STARTER_TELEGRAM_BOT_TOKEN}",
  //         dmPolicy: "pairing",
  //       },
  //     },
  //   },
  // },
}
